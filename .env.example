# izhubs ERP — Environment Variables
# Copy this file to .env.local and fill in the values before starting.
# All variables marked REQUIRED must be set. Others have safe defaults for local dev.

# ----------------------------------------------------------------
# Database — REQUIRED
# ----------------------------------------------------------------
# Full PostgreSQL connection string. This takes precedence over individual vars below.
DATABASE_URL=postgresql://postgres:your_strong_password_here@localhost:5432/izhubs_erp

# Individual DB vars (used by docker-compose.yml)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=izhubs_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here  # Must match DATABASE_URL password

# ----------------------------------------------------------------
# Redis — REQUIRED (used for sessions and future queues)
# ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------------------------------------------
# Auth — REQUIRED
# ----------------------------------------------------------------
# At least 32 random characters each. Generate with: openssl rand -hex 32
JWT_SECRET=your_jwt_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars

# Token expiry
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----------------------------------------------------------------
# App — REQUIRED in production
# ----------------------------------------------------------------
# Public URL of your deployment (used for CORS and links in emails)
NEXT_PUBLIC_APP_URL=http://localhost:1303

# Environment: development | production
NODE_ENV=development

# ----------------------------------------------------------------
# Email — optional (needed for password reset, notifications)
# ----------------------------------------------------------------
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your_smtp_password
# EMAIL_FROM=izhubs ERP <noreply@example.com>

# ----------------------------------------------------------------
# Coolify / Self-host notes
# ----------------------------------------------------------------
# When deploying to Coolify:
# 1. Mark DATABASE_URL, JWT_SECRET, JWT_REFRESH_SECRET as "Persistent" in Coolify UI
# 2. Set NODE_ENV=production
# 3. NEXT_PUBLIC_APP_URL should be your public domain (e.g. https://erp.yourdomain.com)
# 4. After first deploy: run `npm run db:migrate` then `npm run seed:demo` (optional)
