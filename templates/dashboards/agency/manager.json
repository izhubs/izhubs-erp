{
  "role": "manager",
  "industry": "agency",
  "grid": [
    {
      "id": "w_active_projects",
      "type": "SummaryCard",
      "w": 3,
      "title": "Active Projects",
      "icon": "⚡",
      "format": "number",
      "dataSource": { "endpoint": "/api/v1/metrics/projects?status=active" }
    },
    {
      "id": "w_mrr",
      "type": "SummaryCard",
      "w": 3,
      "title": "Monthly Retainer",
      "icon": "💰",
      "format": "currency",
      "dataSource": { "endpoint": "/api/v1/metrics/mrr" }
    },
    {
      "id": "w_open_leads",
      "type": "SummaryCard",
      "w": 3,
      "title": "Open Leads",
      "icon": "🎯",
      "format": "number",
      "dataSource": { "endpoint": "/api/v1/metrics/deals?stage=lead" }
    },
    {
      "id": "w_win_rate",
      "type": "SummaryCard",
      "w": 3,
      "title": "Proposal Win Rate",
      "icon": "🏆",
      "format": "percent",
      "dataSource": { "endpoint": "/api/v1/metrics/win_rate" }
    },
    {
      "id": "w_revenue_chart",
      "type": "ChartWidget",
      "w": 8,
      "title": "Agency Revenue (YTD)",
      "chart_type": "bar",
      "xKey": "month",
      "yKeys": ["revenue"],
      "dataSource": { "endpoint": "/api/v1/metrics/revenue_ytd" }
    },
    {
      "id": "w_recent_clients",
      "type": "DataTableWidget",
      "w": 12,
      "title": "Recent Client Signings",
      "columns": [
        { "header": "Client Name", "accessorKey": "name", "type": "text" },
        { "header": "Services", "accessorKey": "package", "type": "status" },
        { "header": "Retainer", "accessorKey": "value", "type": "currency" },
        { "header": "Start Date", "accessorKey": "closed_at", "type": "date" }
      ],
      "dataSource": { "endpoint": "/api/v1/deals?stage=won&limit=5" }
    }
  ]
}
