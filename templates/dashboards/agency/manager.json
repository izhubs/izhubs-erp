{
  "role": "manager",
  "industry": "agency",
  "grid": [
    {
      "id": "w_project_health",
      "type": "SummaryCard",
      "w": 6,
      "title": "Project Health (Cancel/Hold %)",
      "icon": "⚠️",
      "format": "percent",
      "dataSource": { "endpoint": "/api/v1/metrics/project_health" }
    },
    {
      "id": "w_task_overview",
      "type": "SummaryCard",
      "w": 6,
      "title": "Overdue Tasks",
      "icon": "🚨",
      "format": "number",
      "color": "#ef4444",
      "dataSource": { "endpoint": "/api/v1/metrics/overdue_tasks" }
    },
    {
      "id": "w_team_bottleneck",
      "type": "ChartWidget",
      "w": 6,
      "title": "Team Bottleneck Radar (AM vs SEO vs Media)",
      "chart_type": "bar",
      "xKey": "team",
      "yKeys": ["waiting", "overdue"],
      "dataSource": { "endpoint": "/api/v1/metrics/team_bottleneck" }
    },
    {
      "id": "w_am_leaderboard",
      "type": "DataTableWidget",
      "w": 6,
      "title": "AM Leaderboard",
      "columns": [
        { "header": "Star AM", "accessorKey": "name", "type": "text" },
        { "header": "Completed", "accessorKey": "completed", "type": "number" },
        { "header": "Overdue Needs Push", "accessorKey": "overdue", "type": "number" }
      ],
      "dataSource": { "endpoint": "/api/v1/metrics/am_leaderboard" }
    },
    {
      "id": "w_firefighting",
      "type": "DataTableWidget",
      "w": 12,
      "title": "Firefighting List (Overdue & Pending)",
      "columns": [
        { "header": "Task Name", "accessorKey": "title", "type": "text" },
        { "header": "Project", "accessorKey": "project", "type": "text" },
        { "header": "Assignee", "accessorKey": "assignee", "type": "text" },
        { "header": "Days Late", "accessorKey": "days_late", "type": "number" }
      ],
      "dataSource": { "endpoint": "/api/v1/metrics/firefighting_tasks" }
    }
  ]
}
