{
  "role": "member",
  "industry": "agency",
  "grid": [
    {
      "id": "w_task_overdue",
      "type": "SummaryCard",
      "w": 4,
      "title": "TASK OVERDUE",
      "icon": "🚨",
      "format": "number",
      "color": "#ef4444",
      "dataSource": { "endpoint": "/api/v1/metrics/my_overdue_tasks" }
    },
    {
      "id": "w_due_today",
      "type": "SummaryCard",
      "w": 4,
      "title": "Due Today",
      "icon": "⚠️",
      "format": "number",
      "color": "#f59e0b",
      "dataSource": { "endpoint": "/api/v1/metrics/my_tasks_today" }
    },
    {
      "id": "w_upcoming",
      "type": "SummaryCard",
      "w": 4,
      "title": "Upcoming (3-5 days)",
      "icon": "📅",
      "format": "number",
      "color": "#0ea5e9",
      "dataSource": { "endpoint": "/api/v1/metrics/my_upcoming_tasks" }
    },
    {
      "id": "w_priority_board",
      "type": "DataTableWidget",
      "w": 12,
      "title": "Priority Action Matrix",
      "columns": [
        { "header": "Task", "accessorKey": "title", "type": "text" },
        { "header": "Priority", "accessorKey": "priority", "type": "status" },
        { "header": "Due", "accessorKey": "due_date", "type": "date" },
        { "header": "Quick Action", "accessorKey": "action", "type": "text" }
      ],
      "dataSource": { "endpoint": "/api/v1/metrics/my_priority_tasks" }
    },
    {
      "id": "w_my_active_clients",
      "type": "SummaryCard",
      "w": 6,
      "title": "My Active Clients",
      "icon": "🤝",
      "format": "number",
      "dataSource": { "endpoint": "/api/v1/metrics/my_clients" }
    },
    {
      "id": "w_client_feedback",
      "type": "DataTableWidget",
      "w": 6,
      "title": "Recent Client Feedback",
      "columns": [
        { "header": "Client", "accessorKey": "client", "type": "text" },
        { "header": "Feedback", "accessorKey": "note", "type": "text" },
        { "header": "Status", "accessorKey": "status", "type": "status" }
      ],
      "dataSource": { "endpoint": "/api/v1/metrics/client_feedback" }
    }
  ]
}
