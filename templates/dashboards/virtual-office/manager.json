{
  "role": "manager",
  "industry": "virtual-office",
  "grid": [
    {
      "id": "w_mrr",
      "type": "SummaryCard",
      "w": 3,
      "title": "Monthly Revenue",
      "icon": "💰",
      "format": "currency",
      "dataSource": { "endpoint": "/api/v1/metrics/mrr" }
    },
    {
      "id": "w_active",
      "type": "SummaryCard",
      "w": 3,
      "title": "Active Clients",
      "icon": "✅",
      "format": "number",
      "dataSource": { "endpoint": "/api/v1/metrics/clients?status=active" }
    },
    {
      "id": "w_renewals",
      "type": "SummaryCard",
      "w": 3,
      "title": "Renewals Due",
      "icon": "🔔",
      "format": "number",
      "dataSource": { "endpoint": "/api/v1/metrics/deals?stage=renewal" }
    },
    {
      "id": "w_pipeline_val",
      "type": "SummaryCard",
      "w": 3,
      "title": "Pipeline Value",
      "icon": "📊",
      "format": "currency",
      "dataSource": { "endpoint": "/api/v1/metrics/pipeline_value" }
    },
    {
      "id": "w_revenue_chart",
      "type": "ChartWidget",
      "w": 8,
      "title": "Revenue Forecast (6 Months)",
      "chart_type": "bar",
      "xKey": "month",
      "yKeys": ["arr"],
      "dataSource": { "endpoint": "/api/v1/metrics/revenue_forecast" }
    },
    {
      "id": "w_deal_breakdown",
      "type": "ChartWidget",
      "w": 4,
      "title": "Deals by Stage",
      "chart_type": "donut",
      "xKey": "label",
      "yKeys": ["count"],
      "dataSource": { "endpoint": "/api/v1/metrics/deal_funnel" }
    },
    {
      "id": "w_recent_deals",
      "type": "DataTableWidget",
      "w": 12,
      "title": "Latest Won Contracts",
      "columns": [
        { "header": "Client Name", "accessorKey": "name", "type": "text" },
        { "header": "Package", "accessorKey": "package", "type": "status" },
        { "header": "Value", "accessorKey": "value", "type": "currency" },
        { "header": "Closed Date", "accessorKey": "closed_at", "type": "date" }
      ],
      "dataSource": { "endpoint": "/api/v1/deals?stage=won&limit=5" }
    }
  ]
}
