{
  "name": "izhubs-erp",
  "version": "0.1.0",
  "private": true,
  "description": "izhubs ERP — Open-source, AI-extensible business management. Adapts to your business, not the other way around.",
  "scripts": {
    "dev": "next dev -p 1303",
    "build": "next build",
    "start": "next start -p 1303",
    "verify": "bash scripts/verify.sh",
    "docker:dev": "docker compose up -d",
    "docker:staging": "docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:down": "docker compose down",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "test:contracts": "jest --testPathPattern=tests/contracts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.js",
    "seed:demo": "node scripts/seed.js --industry=agency",
    "seed:agency": "node scripts/seed.js --industry=agency",
    "seed:freelancer": "node scripts/seed.js --industry=freelancer",
    "seed:coworking": "node scripts/seed.js --industry=coworking",
    "seed:restaurant": "node scripts/seed.js --industry=restaurant",
    "seed:cafe": "node scripts/seed.js --industry=cafe",
    "seed:all": "node scripts/seed.js --industry=all"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "bcrypt": "^6.0.0",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "14.2.29",
    "next-intl": "^4.8.3",
    "pg": "^8.13.3",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^2.15.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "jest": "^29",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^29",
    "sass": "^1.98.0",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
