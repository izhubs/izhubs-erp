{
  "name": "izhubs-erp",
  "version": "0.1.0",
  "license": "AGPL-3.0",
  "private": true,
  "description": "izhubs ERP — Open-source, AI-extensible business management. Adapts to your business, not the other way around.",
  "scripts": {
    "dev": "next dev -p 1303",
    "build": "next build",
    "start": "next start -p 1303",
    "verify": "bash scripts/verify.sh",
    "docker:dev": "docker compose up -d",
    "docker:staging": "docker compose -f docker-compose.yml -f docker-compose.staging.yml up -d",
    "docker:prod": "docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d",
    "docker:down": "docker compose down",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "test:unit": "jest --config jest.config.ts --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "test:contracts": "jest --config jest.config.ts --testPathPattern=tests/contracts",
    "backup": "bash scripts/backup.sh",
    "typecheck": "tsc --noEmit",
    "db:migrate": "node scripts/migrate.js",
    "db:reset": "node scripts/db-reset.js",
    "seed:demo": "node scripts/seed.js --industry=agency",
    "seed:agency": "node scripts/seed.js --industry=agency",
    "seed:freelancer": "node scripts/seed.js --industry=freelancer",
    "seed:coworking": "node scripts/seed.js --industry=coworking",
    "seed:restaurant": "node scripts/seed.js --industry=restaurant",
    "seed:cafe": "node scripts/seed.js --industry=cafe",
    "seed:virtual-office": "node scripts/seed.js --industry=virtual-office --lang=en",
    "seed:virtual-office:en": "node scripts/seed.js --industry=virtual-office --lang=en",
    "seed:virtual-office:vi": "node scripts/seed.js --industry=virtual-office --lang=vi",
    "seed:all": "node scripts/seed.js --industry=all",
    "seed:industry-templates": "npx tsx scripts/seed-industry-templates.ts",
    "seed:industry-templates-dry": "npx tsx scripts/seed-industry-templates.ts --dry-run",
    "export:gumroad": "npx tsx scripts/export-gumroad-template.ts --template=agency",
    "export:gumroad:all": "npx tsx scripts/export-gumroad-template.ts --all"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.46.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "@types/papaparse": "^5.5.2",
    "@types/redis": "^4.0.10",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.71.1",
    "driver.js": "^1.4.0",
    "ioredis": "^5.10.1",
    "jose": "^6.2.1",
    "lucide-react": "^0.577.0",
    "next": "14.2.29",
    "next-intl": "^4.8.3",
    "papaparse": "^5.5.3",
    "pg": "^8.13.3",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.71.2",
    "react-select": "^5.10.2",
    "recharts": "^2.15.4",
    "redis": "^5.11.0",
    "sharp": "^0.34.5",
    "vaul": "^1.1.2",
    "zod": "^3.25.76",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@swc/helpers": "^0.5.19",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.29",
    "jest": "^29",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^29",
    "sass": "^1.98.0",
    "ts-jest": "^29",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
